generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Reel {
  id         String         @id @default(cuid())
  url        String         @unique
  thumbnail  String?
  memo       String?
  review     String?
  visited    Boolean        @default(false)
  categories ReelCategory[]
  tags       ReelTag[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Category {
  id    String         @id @default(cuid())
  name  String         @unique
  reels ReelCategory[]
}

model ReelCategory {
  reelId     String
  categoryId String
  reel       Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([reelId, categoryId])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  reels ReelTag[]
}

model ReelTag {
  reelId String
  tagId  String
  reel   Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reelId, tagId])
}
